<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">    
    <changeSet author="fineract" id="ss-0017-1">
        <preConditions onFail="MARK_RAN">
            <and>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM c_external_service WHERE name = 'NationalIdService'
                </sqlCheck>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM c_external_service_properties 
                    WHERE external_service_id = (SELECT id FROM c_external_service WHERE name = 'NationalIdService')
                </sqlCheck>
            </and>
        </preConditions>
        
        <comment>Adding NationalIdService to external services and its properties</comment>
        
        <insert tableName="c_external_service">
            <column name="name" value="NationalIdService"/>
        </insert>

        <insert tableName="c_external_service_properties">
            <column name="name" value="host"/>
            <column name="value" value="https://apis.mifos.community/1.0/nationalid"/>
            <column name="external_service_id" valueComputed="(SELECT id FROM c_external_service WHERE name = 'NationalIdService')"/>
        </insert>

        <insert tableName="c_external_service_properties">
            <column name="name" value="header"/>
            <column name="value" value="X-Gravitee-Api-Key"/>
            <column name="external_service_id" valueComputed="(SELECT id FROM c_external_service WHERE name = 'NationalIdService')"/>
        </insert>

        <insert tableName="c_external_service_properties">
            <column name="name" value="headerValue"/>
            <column name="value" value="0000-0000-0000-0000"/>
            <column name="external_service_id" valueComputed="(SELECT id FROM c_external_service WHERE name = 'NationalIdService')"/>
        </insert>

        <insert tableName="c_external_service_properties">
            <column name="name" value="httpMethod"/>
            <column name="value" value="POST"/>
            <column name="external_service_id" valueComputed="(SELECT id FROM c_external_service WHERE name = 'NationalIdService')"/>
        </insert>
        
        <insert tableName="c_external_service_properties">
            <column name="name" value="parameterName"/>
            <column name="value" value="externalId"/>
            <column name="external_service_id" valueComputed="(SELECT id FROM c_external_service WHERE name = 'NationalIdService')"/>
        </insert>
        
        <insert tableName="c_external_service_properties">
            <column name="name" value="isEnabled"/>
            <column name="value" value="false"/>
            <column name="external_service_id" valueComputed="(SELECT id FROM c_external_service WHERE name = 'NationalIdService')"/>
        </insert>
        
        <rollback>
            <delete tableName="c_external_service_properties">
                <where>external_service_id = (SELECT id FROM c_external_service WHERE name = 'NationalIdService')</where>
            </delete>
            <delete tableName="c_external_service">
                <where>name = 'NationalIdService'</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
